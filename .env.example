# ============================================================
# Emdexer Configuration
# Copy this file to .env and fill in your values.
# Run 'emdex init' to generate secure keys automatically.
#
# This file documents BOTH Gateway and Node variables.
# In a split deployment, each binary only reads its own vars.
# ============================================================

# ─── GATEWAY ENV ────────────────────────────────────────────
# Deploy these on the machine running emdex-gateway.

# Google Gemini API key (embedding + LLM calls)
GOOGLE_API_KEY=your-google-api-key-here

# Qdrant vector database connection
QDRANT_HOST=localhost:6334          # gRPC endpoint
EMDEX_QDRANT_COLLECTION=emdexer_v1

# Gateway REST API authentication (static keys)
EMDEX_AUTH_KEY=
EMDEX_API_KEYS=

# OIDC / JWT Authentication (optional — enables enterprise identity)
# When OIDC_ISSUER is set, JWT tokens are validated first; static keys are fallback.
# OIDC_ISSUER=https://keycloak.internal/realms/emdexer
# OIDC_CLIENT_ID=emdex-gateway
# OIDC_GROUPS_CLAIM=groups

# Group-based namespace ACLs (requires OIDC)
# Maps OIDC groups to authorized namespace lists. ["*"] = wildcard.
# EMDEX_GROUP_ACL={"hr-admins": ["hr", "hiring"], "engineers": ["*"]}

# Gateway HTTP listen port (default: 7700)
EMDEX_PORT=7700

# Global search timeout (ms) for namespace=* fan-out queries
EMDEX_GLOBAL_SEARCH_TIMEOUT=500

# Hybrid Search — BM25 keyword + vector, merged via RRF (Phase 21)
# Set to "false" to fall back to pure vector search (e.g. if the Qdrant
# full-text index has not been created). Default: true (hybrid enabled).
# The node automatically creates the required full-text index on startup.
EMDEX_BM25_ENABLED=true

# RRF tuning — Reciprocal Rank Fusion parameters (Phase 22)
# EMDEX_RRF_K: rank-smoothing constant in 1/(K+rank+1). Default: 60. Higher = gentler slope.
# EMDEX_RRF_VECTOR_WEIGHT: score multiplier for the vector leg. Default: 1.0. Range [0, 10].
# EMDEX_RRF_BM25_WEIGHT:   score multiplier for the BM25 leg.   Default: 1.0. Range [0, 10].
# Set either weight to 0 to exclude that leg entirely.
# EMDEX_RRF_K=60
# EMDEX_RRF_VECTOR_WEIGHT=1.0
# EMDEX_RRF_BM25_WEIGHT=1.0

# Agentic Multi-Hop RAG — iterative retrieval loop (Phase 20)
# EMDEX_AGENTIC_ENABLED: set to "false" to disable and use single-hop RAG. Default: true.
# EMDEX_MAX_HOPS: maximum retrieval hops (1 = single-hop, 2-5 = multi-hop). Default: 3, max: 5.
# EMDEX_HOP_CONFIDENCE_THRESHOLD: LLM confidence score [0.0-1.0] at which the loop stops early.
#   Default: 0.7. Lower = more aggressive early stopping. Higher = more thorough retrieval.
EMDEX_AGENTIC_ENABLED=true
# EMDEX_MAX_HOPS=3
# EMDEX_HOP_CONFIDENCE_THRESHOLD=0.7

# Graph-RAG — filesystem knowledge graph (Phase 24)
# Builds a lightweight in-memory directed graph from import/link relations extracted
# during indexing and uses it to enrich RAG context with structurally adjacent files.
# EMDEX_GRAPH_ENABLED: set to "false" to disable graph expansion. Default: true.
# EMDEX_GRAPH_DEPTH: BFS hop depth when expanding neighbours [1-3]. Default: 1.
#   Depth 1 = direct imports only. Depth 2 = imports-of-imports. Max: 3.
EMDEX_GRAPH_ENABLED=true
# EMDEX_GRAPH_DEPTH=1

# High-Availability mode — requires POSTGRES_URL
# EMDEX_HA_MODE=true
# POSTGRES_URL=postgres://user:pass@db:5432/emdexer?sslmode=require

# Audit logging
EMDEX_AUDIT_LOG_FILE=logs/audit.json

# RAG limits
EMDEX_SEARCH_LIMIT=10
EMDEX_CHAT_LIMIT=5

# ─── NODE ENV ────────────────────────────────────────────────
# Deploy these on the machine running emdex-node.

# Gateway URL — the node registers itself here on startup
EMDEX_GATEWAY_URL=http://localhost:7700
EMDEX_GATEWAY_AUTH_KEY=

# Namespace — every indexed vector will carry this tag
EMDEX_NAMESPACE=default

# VFS (Virtual File System) type: local | smb | sftp | nfs | s3
NODE_TYPE=local
NODE_ROOT=/opt/emdexer/data

# Extractous sidecar URL
EMDEX_EXTRACTOUS_URL=http://localhost:8000/extract

# Indexing Performance & Constraints
EMDEX_BATCH_SIZE=100
EMDEX_MAX_FILE_SIZE=50MB
EMDEX_MAX_ARCHIVE_ENTRY_SIZE=10MB

# Delta-Only Re-indexing (Phase 15.6)
# Set EMDEX_DELTA_ENABLED=0 to disable checksum-based delta detection
# and fall back to stat-only change detection (legacy behaviour).
EMDEX_DELTA_ENABLED=1
# Set EMDEX_FULL_HASH=1 to enable Stage 3 (full XXH3 hash) in addition
# to the default Stage 1 (stat) + Stage 2 (sparse 1 MB head+tail hash).
# Provides maximum accuracy at the cost of reading the entire file.
EMDEX_FULL_HASH=0

# ─── S3 NODE ENV ─────────────────────────────────────────────
# Used when NODE_TYPE=s3. Compatible with AWS S3, MinIO, DigitalOcean Spaces, Wasabi.
S3_ENDPOINT=play.min.io
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_USE_SSL=true
S3_PREFIX=
# S3_REGION=us-east-1

# ─── WHISPER SIDECAR ENV ─────────────────────────────────────
# Whisper.cpp sidecar for audio/video transcription (Zero-Token).
# Set EMDEX_WHISPER_URL to enable. Model options: base, small, medium, large.
EMDEX_WHISPER_URL=http://localhost:8080
EMDEX_WHISPER_MODEL=base

# ─── OCR ─────────────────────────────────────────────────────
# Enable OCR for image files (.png, .jpg, .tiff) and scanned PDF fallback.
# Requires the Extractous sidecar with Tesseract support.
EMDEX_ENABLE_OCR=true

# ─── EXTRACTOUS SIDECAR ENV ─────────────────────────────────
EMDEX_SIDECAR_PORT=8000

# ─── COMMON / SHARED ─────────────────────────────────────────
EMBED_PROVIDER=gemini
EMDEX_GEMINI_MODEL=gemini-embedding-2-preview
# LLM model used by the gateway for chat completions and agentic hop assessment.
# Default: gemini-3-flash-preview. Override to switch models without a rebuild.
EMDEX_LLM_MODEL=gemini-3-flash-preview
NODE_HEALTH_PORT=8081
