# Emdexer environment configuration example.
# Copy to .env and fill in the values.

# ── Embedding providers ───────────────────────────────────────────────────────
GOOGLE_API_KEY=
EMDEX_GEMINI_MODEL=gemini-embedding-2-preview
# EMBED_PROVIDER=gemini  # gemini (default) | ollama | openai
# OPENAI_API_KEY=
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text:v2

# ── Auth ─────────────────────────────────────────────────────────────────────
EMDEX_AUTH_KEY=

# ── Gateway ──────────────────────────────────────────────────────────────────
# EMDEX_PORT=7700
# EMDEX_QDRANT_COLLECTION=emdexer_v1

# ── Prometheus file_sd service discovery ─────────────────────────────────────
# EMDEX_SD_FILE=/etc/prometheus/targets/emdexer_nodes.json

# Host IP to use in Prometheus file_sd targets instead of Docker container hostnames.
# Set to the Docker host IP when Prometheus runs outside Docker.
EMDEX_SD_HOST_OVERRIDE=

# ── Node URL (for external Prometheus scraping) ───────────────────────────────
# Full URL this node advertises to the gateway. Set to the host-mapped address
# when Prometheus runs outside Docker. Default matches port mapping 8083:8081.
# EMDEX_NODE_URL_NODE=http://<host-ip>:8083
