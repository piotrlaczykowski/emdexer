# ============================================================
# Emdexer Configuration
# Copy this file to .env and fill in your values.
# Run 'emdex init' to generate secure keys automatically.
#
# This file documents BOTH Gateway and Node variables.
# In a split deployment, each binary only reads its own vars.
# ============================================================

# ─── GATEWAY ENV ────────────────────────────────────────────
# Deploy these on the machine running emdex-gateway.

# Google Gemini API key (embedding + LLM calls)
GOOGLE_API_KEY=your-google-api-key-here

# Qdrant vector database connection
QDRANT_HOST=localhost:6334          # gRPC endpoint
EMDEX_QDRANT_COLLECTION=emdexer_v1

# Qdrant mTLS (optional — default is plaintext gRPC, unchanged)
# EMDEX_QDRANT_TLS=true             — enable TLS (InsecureSkipVerify when no CA set)
# EMDEX_QDRANT_TLS_CA=<path>        — CA cert PEM for server certificate verification
# EMDEX_QDRANT_TLS_CERT=<path>      — client cert PEM (enables full mTLS)
# EMDEX_QDRANT_TLS_KEY=<path>       — client key PEM  (enables full mTLS)

# Gateway REST API authentication (static keys)
EMDEX_AUTH_KEY=
EMDEX_API_KEYS=

# OIDC / JWT Authentication (optional — enables enterprise identity)
# When OIDC_ISSUER is set, JWT tokens are validated first; static keys are fallback.
# OIDC_ISSUER=https://keycloak.internal/realms/emdexer
# OIDC_CLIENT_ID=emdex-gateway
# OIDC_GROUPS_CLAIM=groups

# Group-based namespace ACLs (requires OIDC)
# Maps OIDC groups to authorized namespace lists. ["*"] = wildcard.
# EMDEX_GROUP_ACL={"hr-admins": ["hr", "hiring"], "engineers": ["*"]}

# Gateway HTTP listen port (default: 7700)
EMDEX_PORT=7700

# Global search timeout (ms) for namespace=* fan-out queries
EMDEX_GLOBAL_SEARCH_TIMEOUT=500

# Hybrid Search — BM25 keyword + vector, merged via RRF (Phase 21)
# Set to "false" to fall back to pure vector search (e.g. if the Qdrant
# full-text index has not been created). Default: true (hybrid enabled).
# The node automatically creates the required full-text index on startup.
EMDEX_BM25_ENABLED=true

# RRF tuning — Reciprocal Rank Fusion parameters (Phase 22)
# EMDEX_RRF_K: rank-smoothing constant in 1/(K+rank+1). Default: 60. Higher = gentler slope.
# EMDEX_RRF_VECTOR_WEIGHT: score multiplier for the vector leg. Default: 1.0. Range [0, 10].
# EMDEX_RRF_BM25_WEIGHT:   score multiplier for the BM25 leg.   Default: 1.0. Range [0, 10].
# Set either weight to 0 to exclude that leg entirely.
# EMDEX_RRF_K=60
# EMDEX_RRF_VECTOR_WEIGHT=1.0
# EMDEX_RRF_BM25_WEIGHT=1.0

# Agentic Multi-Hop RAG — iterative retrieval loop (Phase 20)
# EMDEX_AGENTIC_ENABLED: set to "false" to disable and use single-hop RAG. Default: true.
# EMDEX_MAX_HOPS: maximum retrieval hops (1 = single-hop, 2-5 = multi-hop). Default: 3, max: 5.
# EMDEX_HOP_CONFIDENCE_THRESHOLD: LLM confidence score [0.0-1.0] at which the loop stops early.
#   Default: 0.7. Lower = more aggressive early stopping. Higher = more thorough retrieval.
EMDEX_AGENTIC_ENABLED=true
# EMDEX_MAX_HOPS=3
# EMDEX_HOP_CONFIDENCE_THRESHOLD=0.7

# True LLM token streaming (Phase 37)
# When true (default), /v1/chat/completions stream path calls Gemini's
# streamGenerateContent?alt=sse endpoint so clients receive tokens as they are
# generated. Set to false to revert to the deprecated word-walk fake stream.
EMDEX_STREAM_ENABLED=true

# Graph-RAG — filesystem knowledge graph (Phase 24)
# Builds a lightweight in-memory directed graph from import/link relations extracted
# during indexing and uses it to enrich RAG context with structurally adjacent files.
# EMDEX_GRAPH_ENABLED: set to "false" to disable graph expansion. Default: true.
# EMDEX_GRAPH_DEPTH: BFS hop depth when expanding neighbours [1-3]. Default: 1.
#   Depth 1 = direct imports only. Depth 2 = imports-of-imports. Max: 3.
EMDEX_GRAPH_ENABLED=true
# EMDEX_GRAPH_DEPTH=1
# EMDEX_GRAPH_MIGRATION: auto (default) — detect and trigger re-index if relations missing.
#   skip  — never auto-migrate, manual re-index only.
#   force — always re-index on startup regardless of current state.
EMDEX_GRAPH_MIGRATION=auto

# Late-Interaction Reranking — cross-encoder post-retrieval refinement (Phase 30)
# Disabled by default. Requires the reranker sidecar (src/reranker-sidecar/).
# EMDEX_RERANK_ENABLED: master toggle. Default: false.
# EMDEX_RERANK_URL: reranker sidecar address. Default: http://reranker:8005.
# EMDEX_RERANK_TOP_K: top-K candidates passed to the reranker. Default: 20.
# EMDEX_RERANK_THRESHOLD: minimum rerank score to include a result [0.0-1.0]. Default: 0.0 (no filter).
# EMDEX_RERANK_TOKEN: shared secret for X-Reranker-Token auth. Must match RERANKER_TOKEN on the sidecar.
#   Leave empty in local dev (auth is skipped when the token is unset).
# EMDEX_RERANK_ENABLED=false
# EMDEX_RERANK_URL=http://reranker:8005
# EMDEX_RERANK_TOP_K=20
# EMDEX_RERANK_THRESHOLD=0.0
# EMDEX_RERANK_TOKEN=

# ─── CHUNKING CONFIGURATION ──────────────────────────────────
# EMDEX_CHUNK_SIZE: number of words per chunk. Default: 512.
#   Smaller = more granular retrieval, more vectors stored.
#   Larger = more context per chunk, fewer vectors.
# EMDEX_CHUNK_OVERLAP: overlapping words between adjacent chunks. Default: 50.
#   Overlap preserves context across chunk boundaries.
#   Must be less than EMDEX_CHUNK_SIZE. Clamped automatically if not.
# EMDEX_CHUNK_SIZE=512
# EMDEX_CHUNK_OVERLAP=50
# EMDEX_CHUNK_STRATEGY: chunking strategy. "fixed" (default) or "semantic".
#   "semantic" groups sentences by embedding similarity. More accurate retrieval
#   but slower indexing (~1 embed call per sentence). Requires an embedder.
# EMDEX_CHUNK_STRATEGY=fixed
# EMDEX_SEMANTIC_CHUNK_THRESHOLD=0.7  # cosine similarity threshold [0.0-1.0]
# EMDEX_SEMANTIC_CHUNK_MAX_SIZE=512   # max words per semantic chunk

# ─── CONTEXTUAL RETRIEVAL (Phase 32) ─────────────────────────
# Prepend LLM-generated document context to each chunk before embedding.
# Reduces retrieval failures by ~49-67% for isolated chunks (tables, code,
# short paragraphs). Adds ~1 LLM call per document at index time.
# Default: false. Requires GOOGLE_API_KEY.
# EMDEX_CONTEXTUAL_RETRIEVAL=false
# EMDEX_CONTEXT_MODEL=gemini-3-flash-preview

# ─── OPENTELEMETRY DISTRIBUTED TRACING ──────────────────────
# Backend-agnostic OTLP/gRPC exporter (Jaeger, Tempo, Honeycomb).
# Leave EMDEX_OTEL_ENDPOINT unset to disable tracing entirely (zero overhead).
# EMDEX_OTEL_ENDPOINT=otel-collector:4317
# EMDEX_OTEL_SERVICE_NAME=emdex-gateway
# EMDEX_OTEL_SAMPLING_RATIO=1.0

# High-Availability mode — requires POSTGRES_URL
# EMDEX_HA_MODE=true
# POSTGRES_URL=postgres://user:pass@db:5432/emdexer?sslmode=require

# PostgreSQL read replica (optional) — routes List queries to a replica.
# Write queries always go to POSTGRES_URL. If replica ping fails, falls back to primary.
# EMDEX_PG_REPLICA_URL=postgres://user:pass@replica:5432/emdexer?sslmode=require

# Audit logging
EMDEX_AUDIT_LOG_FILE=logs/audit.json

# RAG limits
EMDEX_SEARCH_LIMIT=10
EMDEX_CHAT_LIMIT=5

# ─── NODE ENV ────────────────────────────────────────────────
# Deploy these on the machine running emdex-node.

# Gateway URL — the node registers itself here on startup
EMDEX_GATEWAY_URL=http://localhost:7700
EMDEX_GATEWAY_AUTH_KEY=

# Namespace — every indexed vector will carry this tag
EMDEX_NAMESPACE=default

# VFS (Virtual File System) type: local | smb | sftp | nfs | s3
NODE_TYPE=local
NODE_ROOT=/opt/emdexer/data

# Extractous sidecar URL
EMDEX_EXTRACTOUS_URL=http://localhost:8000/extract

# Indexing Performance & Constraints
EMDEX_BATCH_SIZE=100
EMDEX_MAX_FILE_SIZE=50MB
EMDEX_MAX_ARCHIVE_ENTRY_SIZE=10MB

# Delta-Only Re-indexing (Phase 15.6)
# Set EMDEX_DELTA_ENABLED=0 to disable checksum-based delta detection
# and fall back to stat-only change detection (legacy behaviour).
EMDEX_DELTA_ENABLED=1
# Set EMDEX_FULL_HASH=1 to enable Stage 3 (full XXH3 hash) in addition
# to the default Stage 1 (stat) + Stage 2 (sparse 1 MB head+tail hash).
# Provides maximum accuracy at the cost of reading the entire file.
EMDEX_FULL_HASH=0

# ─── S3 NODE ENV ─────────────────────────────────────────────
# Used when NODE_TYPE=s3. Compatible with AWS S3, MinIO, DigitalOcean Spaces, Wasabi.
S3_ENDPOINT=play.min.io
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_USE_SSL=true
S3_PREFIX=
# S3_REGION=us-east-1

# ─── MULTI-MODAL HARDENING (Phase 26) ───────────────────────
# All three tracks are opt-in. Default deployment is unchanged.

# Track 1 — Whisper (Audio/Video Transcription)
# EMDEX_WHISPER_ENABLED: master toggle — must be "true" to transcribe. Default: false.
# EMDEX_WHISPER_URL: Whisper.cpp sidecar address.
# EMDEX_WHISPER_MODEL: base | small | medium | large. Default: base.
# EMDEX_WHISPER_MIN_CHARS: skip transcripts shorter than N chars. Default: 50.
# EMDEX_WHISPER_LANGUAGE: optional language hint (e.g. "en") passed to the API.
# EMDEX_WHISPER_ENABLED=false
EMDEX_WHISPER_URL=http://localhost:8080
EMDEX_WHISPER_MODEL=base
# EMDEX_WHISPER_MIN_CHARS=50
# EMDEX_WHISPER_LANGUAGE=

# Track 2 — Gemini Vision (Image Captioning)
# EMDEX_VISION_ENABLED: master toggle — uses GOOGLE_API_KEY for Gemini Vision. Default: false.
#   Vision takes priority over OCR when both are enabled.
# EMDEX_VISION_MAX_SIZE_MB: skip images larger than this. Default: 10.
# EMDEX_VISION_ENABLED=false
# EMDEX_VISION_MAX_SIZE_MB=10

# Track 3 — FFmpeg (Video Frame Extraction)
# EMDEX_FRAME_ENABLED: master toggle. Requires EMDEX_FFMPEG_URL. Default: false.
# EMDEX_FFMPEG_URL: FFmpeg sidecar address (see src/ffmpeg-sidecar/).
# EMDEX_FRAME_INTERVAL_SEC: seconds between extracted frames. Default: 30.
# EMDEX_MAX_FRAMES: maximum frames per video. Default: 10.
# EMDEX_FRAME_ENABLED=false
# EMDEX_FFMPEG_URL=http://localhost:8004
# EMDEX_FRAME_INTERVAL_SEC=30
# EMDEX_MAX_FRAMES=10

# ─── OCR ─────────────────────────────────────────────────────
# Enable OCR for image files (.png, .jpg, .tiff) and scanned PDF fallback.
# Requires the Extractous sidecar with Tesseract support.
EMDEX_ENABLE_OCR=true

# ─── EXTRACTOUS SIDECAR ENV ─────────────────────────────────
EMDEX_SIDECAR_PORT=8000

# ─── EXTRACTOR PLUGINS ───────────────────────────────────────
# Drop *.py plugin files into EMDEX_PLUGIN_DIR and they are loaded automatically
# on node startup — no recompilation required.
# Set EMDEX_PLUGIN_ENABLED=false to disable the plugin system entirely.
EMDEX_PLUGIN_ENABLED=true
EMDEX_PLUGIN_DIR=./plugins
# EMDEX_PLUGIN_TIMEOUT=10s
#
# Plugin Runner Sidecar — recommended for Docker/Kubernetes deployments.
# When EMDEX_PLUGIN_SIDECAR_URL is set, plugins are discovered from and executed
# by the plugin-sidecar HTTP service instead of spawning Python subprocesses.
# This avoids the need for Python inside the Go node container.
# Format: http://<host>:<port>/extract
# Leave unset to use the subprocess runner (requires Python on PATH — dev/local only).
# EMDEX_PLUGIN_SIDECAR_URL=http://localhost:8003/extract

# ─── COMMON / SHARED ─────────────────────────────────────────
EMBED_PROVIDER=gemini
EMDEX_GEMINI_MODEL=gemini-embedding-2-preview
# LLM model used by the gateway for chat completions and agentic hop assessment.
# Default: gemini-3-flash-preview. Override to switch models without a rebuild.
EMDEX_LLM_MODEL=gemini-3-flash-preview
NODE_HEALTH_PORT=8081

# ─── RERANKER SIDECAR ENV (Phase 30) ────────────────────────
# Set these on the machine/container running src/reranker-sidecar/.
# RERANKER_MODEL: HuggingFace cross-encoder model name. Default: cross-encoder/ms-marco-MiniLM-L-6-v2.
# RERANKER_DEVICE: torch device — "cpu" or "cuda". Default: cpu.
# MAX_TEXTS: max texts accepted per /rerank request. Default: 100.
# RERANKER_TOKEN: shared secret validated via X-Reranker-Token header (auth not yet active — pending Task 4).
#   Must match EMDEX_RERANK_TOKEN on the gateway. Leave empty to disable auth (dev only).
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANKER_DEVICE=cpu
# MAX_TEXTS=100
# RERANKER_TOKEN=
