# ── Core ─────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
EMDEX_AUTH_KEY=
EMDEX_GATEWAY_AUTH_KEY=

# ── Prometheus SD host override ───────────────────────────────────────────────
# Host IP to use in Prometheus file_sd targets instead of Docker container hostnames.
# Set to the Docker host IP when Prometheus runs outside Docker.
# Example: EMDEX_SD_HOST_OVERRIDE=192.168.1.100
EMDEX_SD_HOST_OVERRIDE=

# ── Node URL override (node service) ─────────────────────────────────────────
# Full URL this node advertises to the gateway for health checks and metrics.
# Must be reachable from the gateway container. Default: http://localhost:8083
EMDEX_NODE_URL=

# ── Service Configuration ────────────────────────────────────────────────────
EMDEX_PORT=8083
EMDEX_NODE_ID=
EMDEX_NAMESPACE=default
NODE_TYPE=indexer
NODE_ROOT=/data
NODE_HEALTH_PORT=8081

# ── Database & Storage ───────────────────────────────────────────────────────
POSTGRES_URL=
EMDEX_QDRANT_COLLECTION=documents
QDRANT_HOST=localhost:6334
QDRANT_HTTP_HOST=localhost:6333
EMDEX_QUEUE_DB=file:///data/queue.db

# ── Embedding Provider ───────────────────────────────────────────────────────
EMBED_PROVIDER=google
EMDEX_EMBEDDING_DIMS=768
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBED_MODEL=text-embedding-3-small
OLLAMA_HOST=localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMS=768

# ── LLM Configuration ────────────────────────────────────────────────────────
EMDEX_LLM_MODEL=claude-3-5-sonnet-20241022
EMDEX_CONTEXT_MODEL=
EMDEX_GEMINI_MODEL=
EMDEX_BATCH_SIZE=10

# ── Indexing & Processing ───────────────────────────────────────────────────
EMDEX_INDEX_WORKERS=4
EMDEX_CHUNK_STRATEGY=semantic
EMDEX_EXTRACT_CACHE_SIZE=100
EMDEX_EMBED_TIMEOUT=30s
EMDEX_FULL_HASH=false

# ── Feature Flags ────────────────────────────────────────────────────────────
EMDEX_BM25_ENABLED=true
EMDEX_GRAPH_ENABLED=true
EMDEX_DELTA_ENABLED=false
EMDEX_PLUGIN_ENABLED=false
EMDEX_AGENTIC_ENABLED=false
EMDEX_VISION_ENABLED=false
EMDEX_STREAM_ENABLED=false
EMDEX_FRAME_ENABLED=false
EMDEX_ENABLE_OCR=false
EMDEX_WHISPER_ENABLED=false
EMDEX_RERANK_ENABLED=false
EMDEX_CONTEXTUAL_RETRIEVAL=false

# ── Search Configuration ─────────────────────────────────────────────────────
EMDEX_GLOBAL_SEARCH_TIMEOUT=30s
EMDEX_RRF_K=60
EMDEX_RRF_BM25_WEIGHT=1.0
EMDEX_RRF_VECTOR_WEIGHT=1.0
EMDEX_GRAPH_DEPTH=2
EMDEX_MAX_HOPS=5
EMDEX_HOP_CONFIDENCE_THRESHOLD=0.7
EMDEX_RERANK_THRESHOLD=0.5
EMDEX_RERANK_TOP_K=10

# ── Gateway Configuration ────────────────────────────────────────────────────
EMDEX_GATEWAY_URL=http://localhost:8082
GATEWAY_URL=

# ── File Sources & Storage ──────────────────────────────────────────────────
EMDEX_EXCLUDE_PATHS=
EMDEX_MAX_ARCHIVE_MB=500
EMDEX_MAX_ARCHIVE_ENTRY_SIZE=100

# ── NFS Configuration ───────────────────────────────────────────────────────
NFS_HOST=
NFS_PATH=/exports

# ── SMB/CIFS Configuration ──────────────────────────────────────────────────
SMB_HOST=
SMB_SHARE=
SMB_USER=
SMB_PASS=

# ── SFTP Configuration ───────────────────────────────────────────────────────
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASS=

# ── S3 Configuration ────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=
S3_PREFIX=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true

# ── External Services ───────────────────────────────────────────────────────
EMDEX_EXTRACTOUS_URL=
EMDEX_FFMPEG_URL=
EMDEX_PLUGIN_SIDECAR_URL=
EMDEX_PLUGIN_TIMEOUT=10s
EMDEX_WHISPER_URL=
EMDEX_WHISPER_MODEL=base
EMDEX_WHISPER_LANGUAGE=
EMDEX_RERANK_URL=
EMDEX_RERANK_TOKEN=

# ── Graph & Migration ───────────────────────────────────────────────────────
EMDEX_GRAPH_MIGRATION=false

# ── Caching & Performance ───────────────────────────────────────────────────
EMDEX_CACHE_DIR=/tmp/emdexer_cache
EMDEX_EMBED_CACHE_SIZE=1000

# ── Observability ───────────────────────────────────────────────────────────
EMDEX_OTEL_ENDPOINT=
EMDEX_OTEL_SERVICE_NAME=emdexer
EMDEX_OTEL_SAMPLING_RATIO=1.0
EMDEX_AUDIT_LOG_FILE=/var/log/emdexer/audit.log
EMDEX_AUDIT_BUFFER_SIZE=1000

# ── High Availability ───────────────────────────────────────────────────────
EMDEX_HA_MODE=false
EMDEX_PG_REPLICA_URL=

# ── TLS/Security (Qdrant) ───────────────────────────────────────────────────
EMDEX_QDRANT_TLS=false
EMDEX_QDRANT_TLS_CA=
EMDEX_QDRANT_TLS_CERT=
EMDEX_QDRANT_TLS_KEY=

# ── Authentication (OIDC) ───────────────────────────────────────────────────
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_GROUPS_CLAIM=

# ── Access Control ───────────────────────────────────────────────────────────
EMDEX_GROUP_ACL=

# ── Plugin System ────────────────────────────────────────────────────────────
EMDEX_PLUGIN_DIR=/plugins
EMDEX_REGISTRY_FILE=

# ── Docker Compose ───────────────────────────────────────────────────────────
EMDEX_COMPOSE_FILE=docker-compose.yml

# ── Service Discovery ───────────────────────────────────────────────────────
EMDEX_SD_FILE=
EMDEX_API_KEYS=

# ── Telegram Integration ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
