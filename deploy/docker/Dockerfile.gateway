FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY src/gateway/go.mod src/gateway/go.sum ./
RUN go mod download
COPY src/gateway/ .
COPY src/pkg/ /app/src/pkg/
RUN go build -o emdexer-gateway main.go

FROM alpine:latest
WORKDIR /app
RUN apk add --no-cache curl
COPY --from=builder /app/emdexer-gateway .
CMD ["./emdexer-gateway"]
