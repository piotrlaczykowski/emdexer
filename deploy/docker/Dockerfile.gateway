FROM golang:1.26.1-alpine AS builder
WORKDIR /app
COPY src/gateway/go.mod src/gateway/go.sum ./
RUN go mod download
COPY src/gateway/ .
COPY src/pkg/ /app/src/pkg/
RUN go build -o emdexer-gateway main.go

FROM alpine:3.21
RUN apk add --no-cache curl
WORKDIR /app
RUN addgroup -S emdexer && adduser -S emdexer -G emdexer
COPY --from=builder /app/emdexer-gateway .
RUN chown -R emdexer:emdexer /app
USER emdexer
CMD ["./emdexer-gateway"]
