FROM golang:1.26.1-alpine AS builder

WORKDIR /app

# Copy shared pkg first as it's a dependency for go mod download in node
COPY src/pkg/ src/pkg/
COPY src/node/ src/node/

WORKDIR /app/src/node
RUN go mod download
RUN go build -o /app/emdexer-node .

FROM alpine:3.21
RUN apk add --no-cache curl
WORKDIR /app
RUN addgroup -S emdexer && adduser -S emdexer -G emdexer
COPY --from=builder /app/emdexer-node .
RUN chown -R emdexer:emdexer /app
USER emdexer
CMD ["./emdexer-node"]
