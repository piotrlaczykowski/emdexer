FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY src/node/go.mod src/node/go.sum ./
RUN go mod download
COPY src/node/ .
COPY src/pkg/ /app/src/pkg/
RUN go build -o emdexer-node main.go

FROM alpine:latest
RUN apk add --no-cache curl
WORKDIR /app
RUN addgroup -S emdexer && adduser -S emdexer -G emdexer
COPY --from=builder /app/emdexer-node .
RUN chown -R emdexer:emdexer /app
USER emdexer
CMD ["./emdexer-node"]
