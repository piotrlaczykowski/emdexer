        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum(rate(emdexer_node_whisper_retries_total[5m]))",
          "legendFormat": "retries/s"
